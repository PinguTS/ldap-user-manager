# LDAP User Manager with OIDC Configuration
# Copy this file to .env and update with your values

# =============================================================================
# OIDC Configuration
# =============================================================================
OIDC_ENABLED=true
OIDC_ISSUER=https://id.example.org
OIDC_CLIENT_ID=ldap-user-manager
OIDC_CLIENT_SECRET=your-client-secret-here
OIDC_REDIRECT_URI=https://app.example.org/oidc/callback
OIDC_SCOPES=openid profile email groups

# =============================================================================
# LDAP Connection Settings
# =============================================================================
LDAP_URI=ldaps://ldap-server:636
LDAP_BASE_DN=dc=example,dc=com
LDAP_ADMIN_BIND_DN=cn=admin,dc=example,dc=com
LDAP_ADMIN_BIND_PWD=admin123
LDAP_REQUIRE_STARTTLS=false
LDAP_IGNORE_CERT_ERRORS=true

# =============================================================================
# LDAP Structure
# =============================================================================
LDAP_USER_OU=people
LDAP_ORG_OU=organizations
LDAP_GROUP_OU=roles
LDAP_ACCOUNT_ATTRIBUTE=mail
LDAP_USE_UUID_IDENTIFICATION=true

# =============================================================================
# Role Name Configuration (must be unique)
# =============================================================================
LDAP_ADMIN_ROLE=administrators
LDAP_MAINTAINER_ROLE=maintainers
LDAP_ORG_ADMIN_ROLE=org_admin
LDAP_USER_ROLE=user

# =============================================================================
# Status Group Names (cn= values under ou=roles; used for membership/disabled flags)
# =============================================================================
LDAP_GROUP_MEMBER_ORGS=memberOrganizations
LDAP_GROUP_DISABLED_ORGS=disabledOrganizations
LDAP_GROUP_DISABLED_ACCOUNTS=disabledAccounts

# =============================================================================
# Application Settings
# =============================================================================
ORGANISATION_NAME=LDAP User Manager
SITE_NAME=LDAP User Manager
SERVER_HOSTNAME=app.example.org
SERVER_PATH=/

# =============================================================================
# Security Settings
# =============================================================================
NO_HTTPS=true

# =============================================================================
# Session Security
# =============================================================================
# SESSION_TIMEOUT is in minutes (default: 60 = 1 hour)
SESSION_TIMEOUT=60
# SESSION_SAVE_PATH: directory for app session files.
# Container image default: /var/lib/ldap_user_manager/sessions (created in Dockerfile/entrypoint).
# For non-Docker or override: set to a writable path. For multiple instances, use a shared path (e.g. mounted volume).
# SESSION_SAVE_PATH=/var/lib/ldap_user_manager/sessions
SESSION_REGENERATE_ID=TRUE
SESSION_SECURE_COOKIES=TRUE
SESSION_HTTP_ONLY=TRUE
SESSION_SAME_SITE=strict

# =============================================================================
# Rate Limiting (login attempts)
# =============================================================================
RATE_LIMIT_MAX_ATTEMPTS=5
RATE_LIMIT_TIME_WINDOW=300
RATE_LIMIT_LOCKOUT_DURATION=900

# =============================================================================
# Password Policy
# =============================================================================
PASSWORD_STRENGTH_MIN_SCORE=2
PASSWORD_STRENGTH_MIN_LENGTH=8
PASSWORD_STRENGTH_REQUIRE_UPPERCASE=TRUE
PASSWORD_STRENGTH_REQUIRE_LOWERCASE=TRUE
PASSWORD_STRENGTH_REQUIRE_NUMBERS=TRUE
ACCEPT_WEAK_PASSWORDS=false

# =============================================================================
# Audit Logging
# =============================================================================
AUDIT_LOG_ENABLED=TRUE
AUDIT_LOG_LEVEL=INFO
AUDIT_LOG_FILE=/var/log/ldap_user_manager/audit.log

# =============================================================================
# Runtime Environment (development | test | production)
# =============================================================================
ENVIRONMENT=production

# =============================================================================
# User Management Settings
# =============================================================================
DEFAULT_USER_GROUP=everybody
USERNAME_FORMAT={first_name}-{last_name}
PASSWORD_HASH=SSHA

# =============================================================================
# Account Requests
# =============================================================================
ACCOUNT_REQUESTS_ENABLED=true

# =============================================================================
# Debug Settings
# =============================================================================
LDAP_DEBUG=false
SESSION_DEBUG=false
SETUP_DEBUG=false

# =============================================================================
# Optional: Email Configuration
# =============================================================================
# SMTP_HOSTNAME=smtp.example.com
# SMTP_USERNAME=noreply@example.com
# SMTP_PASSWORD=your-smtp-password
# SMTP_USE_TLS=TRUE
# EMAIL_TEMPLATES_DIR=   # Overrides default www/templates/emails; use absolute path. Empty = default.
# EMAIL_DEFAULT_LOCALE=  # Installation default in recipient locale chain; sole locale for system/service invites. Empty = skip that step.
# EMAIL_USER_LOCALE_LDAP_ATTR=preferredLanguage  # User LDAP attribute for preferred email locale; set to empty to disable.
# EMAIL_ORG_LOCALE_LDAP_ATTR=  # Org LDAP attribute for default email locale (optional; requires schema support).
# EMAIL_COUNTRY_LOCALE_MAP=  # e.g. DE=de,FR=fr or JSON {"DE":"de","FR":"fr"} — maps org postal country to locale.
# EMAIL_SYSTEM_ACCOUNT_ROLES=  # Optional override; comma-separated description values. Default: admin role + maintainer.

# =============================================================================
# External Services OIDC Configuration
# =============================================================================
# These services run on external servers, not in this Docker environment
TYPO3_CLIENT_SECRET=your-typo3-client-secret-here
GITLAB_CLIENT_SECRET=your-gitlab-client-secret-here
NEXTCLOUD_CLIENT_SECRET=your-nextcloud-client-secret-here

# =============================================================================
# TYPO3 / Member Organizations Export
# =============================================================================
# Export endpoint: GET /export/organizations.php?format=json|json_typo3|csv
# Auth: Authorization: Bearer <EXPORT_SHARED_SECRET>
# Generate secret: openssl rand -hex 32 (min 32 chars). Empty = endpoint returns 503.
EXPORT_SHARED_SECRET=
TYPO3_EXPORT_PID=0

# =============================================================================
# Production Overrides
# =============================================================================
# For production, uncomment and set these:
# ENVIRONMENT=production
# LDAP_IGNORE_CERT_ERRORS=false
# LDAP_REQUIRE_STARTTLS=true
# EXPORT_SHARED_SECRET=<output of: openssl rand -hex 32>
