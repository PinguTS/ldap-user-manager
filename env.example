# LDAP User Manager with OIDC Configuration
# Copy this file to .env and update with your values

# =============================================================================
# OIDC Configuration
# =============================================================================
OIDC_ENABLED=true
OIDC_ISSUER=https://id.example.org
OIDC_CLIENT_ID=ldap-user-manager
OIDC_CLIENT_SECRET=your-client-secret-here
OIDC_REDIRECT_URI=https://app.example.org/oidc/callback
OIDC_SCOPES=openid profile email groups

# =============================================================================
# LDAP Connection Settings
# =============================================================================
LDAP_URI=ldaps://ldap-server:636
LDAP_BASE_DN=dc=example,dc=com
LDAP_ADMIN_BIND_DN=cn=admin,dc=example,dc=com
LDAP_ADMIN_BIND_PWD=admin123

# =============================================================================
# Application Settings
# =============================================================================
ORGANISATION_NAME=LDAP User Manager
SITE_NAME=LDAP User Manager
SERVER_HOSTNAME=app.example.org
SERVER_PATH=/

# =============================================================================
# Security Settings
# =============================================================================
LDAP_REQUIRE_STARTTLS=false
LDAP_IGNORE_CERT_ERRORS=true
NO_HTTPS=true

# =============================================================================
# User Management Settings
# =============================================================================
DEFAULT_USER_GROUP=everybody
USERNAME_FORMAT={first_name}-{last_name}
PASSWORD_HASH=SSHA
ACCEPT_WEAK_PASSWORDS=false

# =============================================================================
# Account Requests
# =============================================================================
ACCOUNT_REQUESTS_ENABLED=true

# =============================================================================
# Debug Settings
# =============================================================================
LDAP_DEBUG=false
SESSION_DEBUG=false
SETUP_DEBUG=false

# =============================================================================
# Optional: Email Configuration
# =============================================================================
# SMTP_HOSTNAME=smtp.example.com
# SMTP_USERNAME=noreply@example.com
# SMTP_PASSWORD=your-smtp-password
# SMTP_USE_TLS=TRUE

# =============================================================================
# External Services OIDC Configuration
# =============================================================================
# These services run on external servers, not in this Docker environment
TYPO3_CLIENT_SECRET=your-typo3-client-secret-here
GITLAB_CLIENT_SECRET=your-gitlab-client-secret-here
NEXTCLOUD_CLIENT_SECRET=your-nextcloud-client-secret-here

# =============================================================================
# Production Overrides
# =============================================================================
# For production, uncomment and set these:
# ENVIRONMENT=production
# LDAP_IGNORE_CERT_ERRORS=false
# LDAP_REQUIRE_STARTTLS=true
