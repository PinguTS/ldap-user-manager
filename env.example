# LDAP User Manager - Environment Configuration
# Copy this file to .env and update with your values

# =============================================================================
# OIDC Configuration
# Required only when OIDC_ENABLED=true
# =============================================================================
OIDC_ENABLED=true
OIDC_ISSUER=https://id.example.org
OIDC_CLIENT_ID=ldap-user-manager
OIDC_CLIENT_SECRET=<CHANGEME-oidc-client-secret>
OIDC_REDIRECT_URI=https://app.example.org/oidc/callback
OIDC_SCOPES=openid profile email groups

# =============================================================================
# LDAP Connection Settings
# =============================================================================
LDAP_URI=ldaps://ldap-server:636
LDAP_BASE_DN=dc=example,dc=com
LDAP_ADMIN_BIND_DN=cn=admin,dc=example,dc=com
LDAP_ADMIN_BIND_PWD=<CHANGEME-strong-ldap-admin-password>
# STARTTLS is enforced by default. Set to false only for ldaps:// connections or local dev.
LDAP_REQUIRE_STARTTLS=true
# Certificate validation is enforced by default. Never set to true in production.
LDAP_IGNORE_CERT_ERRORS=false

# =============================================================================
# LDAP Structure
# =============================================================================
LDAP_USER_OU=people
LDAP_ORG_OU=organizations
LDAP_GROUP_OU=roles
LDAP_ACCOUNT_ATTRIBUTE=mail
LDAP_USE_UUID_IDENTIFICATION=true

# =============================================================================
# Role Name Configuration (must be unique)
# =============================================================================
LDAP_ADMIN_ROLE=administrators
LDAP_MAINTAINER_ROLE=maintainers
LDAP_ORG_ADMIN_ROLE=org_admin
LDAP_USER_ROLE=user

# =============================================================================
# Status Group Names (cn= values under ou=roles; used for membership/disabled flags)
# =============================================================================
LDAP_GROUP_MEMBER_ORGS=memberOrganizations
LDAP_GROUP_DISABLED_ORGS=disabledOrganizations
LDAP_GROUP_DISABLED_ACCOUNTS=disabledAccounts

# =============================================================================
# Application Settings
# =============================================================================
ORGANISATION_NAME=LDAP User Manager
SITE_NAME=LDAP User Manager
SERVER_HOSTNAME=app.example.org
SERVER_PATH=/

# =============================================================================
# Security Settings
# =============================================================================
# Set to true only if running behind a reverse proxy that terminates HTTPS
NO_HTTPS=true

# =============================================================================
# State directory (setup lock + rate-limit files)
# =============================================================================
# LUM_STATE_DIR: writable directory for setup-lock and rate-limit files.
# Default: /var/lib/ldap_user_manager  (auto-created if it does not exist)
# Set this to a persistent volume path when running multiple replicas.
# LUM_STATE_DIR=/var/lib/ldap_user_manager

# =============================================================================
# Session Security
# =============================================================================
# SESSION_TIMEOUT is in minutes (default: 60 = 1 hour)
SESSION_TIMEOUT=60
# SESSION_SAVE_PATH: directory for app session files.
# Container image default: /var/lib/ldap_user_manager/sessions (created in Dockerfile/entrypoint).
# For non-Docker or override: set to a writable path. For multiple instances, use a shared path (e.g. mounted volume).
# SESSION_SAVE_PATH=/var/lib/ldap_user_manager/sessions

# NOT YET IMPLEMENTED - planned session hardening variables:
# When implemented, these will allow fine-grained control over session cookie security.
# SESSION_REGENERATE_ID=TRUE        # Regenerate session ID on login (prevents session fixation)
# SESSION_SECURE_COOKIES=TRUE       # Mark session cookies as Secure (HTTPS-only)
# SESSION_HTTP_ONLY=TRUE            # Mark session cookies as HttpOnly (no JS access)
# SESSION_SAME_SITE=strict          # SameSite cookie policy: strict | lax | none

# =============================================================================
# Rate Limiting (login attempts)
# =============================================================================
# NOT YET IMPLEMENTED - planned configurable rate limiting:
# Currently hardcoded to 5 attempts per 5 minutes with 15-minute lockout.
# When implemented, these variables will override the defaults.
# RATE_LIMIT_MAX_ATTEMPTS=5         # Max failed login attempts before lockout
# RATE_LIMIT_TIME_WINDOW=300        # Time window in seconds (default: 5 minutes)
# RATE_LIMIT_LOCKOUT_DURATION=900   # Lockout duration in seconds (default: 15 minutes)

# =============================================================================
# Password Policy
# =============================================================================
PASSWORD_STRENGTH_MIN_SCORE=2
PASSWORD_STRENGTH_MIN_LENGTH=8
PASSWORD_STRENGTH_REQUIRE_UPPERCASE=TRUE
PASSWORD_STRENGTH_REQUIRE_LOWERCASE=TRUE
PASSWORD_STRENGTH_REQUIRE_NUMBERS=TRUE
ACCEPT_WEAK_PASSWORDS=false

# =============================================================================
# Audit Logging
# =============================================================================
AUDIT_LOG_ENABLED=TRUE
AUDIT_LOG_FILE=/var/log/ldap_user_manager/audit.log
# NOT YET IMPLEMENTED - planned configurable log verbosity:
# AUDIT_LOG_LEVEL=INFO              # Log level: DEBUG | INFO | WARN | ERROR

# =============================================================================
# Organization change history (OpenLDAP accesslog overlay)
# =============================================================================
# Set to true to display who changed organization attributes and when.
# Requires the OpenLDAP accesslog overlay to be active on the LDAP server
# (LDAP_BACKEND_OVERLAY_ACCESSLOG=true for osixia images, or manual ldapmodify).
# The app bind DN (LDAP_ADMIN_BIND_DN) must have read access to cn=accesslog.
# See docker/openldap/README.md for full setup instructions.
LDAP_ACCESSLOG_ENABLED=false

# =============================================================================
# User-bound /manage and setup (OpenLDAP olcAccess)
# =============================================================================
# After password login, the app stores an encrypted copy of the LDAP password in the PHP
# session (key in the browser cookie) and binds as the logged-in user for /manage. SSO,
# header-based login, and one-time token flows have no password: the app uses
# LDAP_ADMIN_BIND for those requests instead.
# Role-based LDAP ACLs (olcAccess on cn=config):
# For user-bind write operations to work (so each user's session bind is used for writes,
# rather than the admin service account), OpenLDAP must have olcAccess rules that grant write
# access based on group membership (administrators, maintainers, org admins).
# The setup wizard at /setup/apply_user_bind_acls.php applies a baseline (Step 1: read + self
# password write) and role-based write rules (Step 2: group-scoped write per role), with
# copy/paste ldapmodify commands filled from your environment.
# See docs/ldap/userbind-acls.md for the full rule set, explanation, and ldapsearch verification.
#
# Override the MDB DN if your main database is not olcDatabase={1}mdb,cn=config:
# LDAP_OLC_MDB_DN=olcDatabase={1}mdb,cn=config
#
# When user-bind LDAP credentials are in the session but the LDAP bind fails (e.g. the
# user's LDAP password was changed externally), the app can either:
#   true  (default) — fall back to the admin service account so the session continues.
#                     Writes still succeed but LDAP accesslog records the service account DN.
#   false           — deny write operations for that request and clear the stale credentials.
#                     The user's next request will re-authenticate via admin bind (read-only),
#                     and they will need to re-login to restore user-bind accountability.
# LUM_WRITE_BIND_FALLBACK=true
#
# Optional: show a thin debug bar on /manage (global admin or maintainer only) with the
# current LDAP bind mode for this HTTP request (user vs. admin vs. admin fallback).
# LUM_DEBUG_MANAGE_BIND=true

# =============================================================================
# Runtime Environment (development | test | production)
# =============================================================================
ENVIRONMENT=production

# =============================================================================
# User Management Settings
# =============================================================================
DEFAULT_USER_GROUP=everybody
USERNAME_FORMAT={first_name}-{last_name}
PASSWORD_HASH=SSHA

# =============================================================================
# Account Requests
# =============================================================================
ACCOUNT_REQUESTS_ENABLED=true

# =============================================================================
# Password set/reset link tokens (requires SMTP)
# =============================================================================
# Required to enable link-based password set/reset flows (no password in email).
# Generate with: openssl rand -hex 32
# Rotate this value to immediately invalidate all outstanding links.
# PASSWORD_RESET_TOKEN_SECRET=
# PASSWORD_RESET_TOKEN_TTL_SECONDS=3600   # Link expiry in seconds (default: 60 minutes)

# =============================================================================
# Debug Settings
# =============================================================================
LDAP_DEBUG=false
SESSION_DEBUG=false
SETUP_DEBUG=false

# =============================================================================
# Optional: Email / SMTP Configuration
# =============================================================================
# SMTP_HOSTNAME=smtp.example.com
# SMTP_USERNAME=noreply@example.com
# SMTP_PASSWORD=your-smtp-password
# SMTP_HOST_PORT=587
# SMTP_USE_TLS=TRUE
# EMAIL_FROM_ADDRESS=noreply@example.com
# EMAIL_FROM_NAME=LDAP User Manager
# EMAIL_TEMPLATES_DIR=   # Overrides default www/templates/emails; use absolute path.
# EMAIL_DEFAULT_LOCALE=  # Installation default in recipient locale chain. Empty = skip.
# EMAIL_USER_LOCALE_LDAP_ATTR=preferredLanguage  # User LDAP attribute for email locale.
# EMAIL_ORG_LOCALE_LDAP_ATTR=   # Org LDAP attribute for default email locale.
# EMAIL_COUNTRY_LOCALE_MAP=     # e.g. DE=de,FR=fr  or JSON {"DE":"de","FR":"fr"}

# =============================================================================
# Member Organizations Export
# =============================================================================
# Export endpoint: GET /export/organizations.php?format=json|json_typo3|csv
# Auth: Authorization: Bearer <EXPORT_SHARED_SECRET>
# Generate secret: openssl rand -hex 32 (min 32 chars). Empty = endpoint returns 503.
# EXPORT_SHARED_SECRET=
# TYPO3_EXPORT_PID=0

# =============================================================================
# Production Overrides
# =============================================================================
# For production, uncomment and set these:
# ENVIRONMENT=production
# NO_HTTPS=false
# LDAP_IGNORE_CERT_ERRORS=false
# LDAP_REQUIRE_STARTTLS=true
# EXPORT_SHARED_SECRET=<output of: openssl rand -hex 32>
# PASSWORD_RESET_TOKEN_SECRET=<output of: openssl rand -hex 32>
