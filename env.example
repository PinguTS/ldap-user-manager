# LDAP User Manager - Environment Configuration
# Copy this file to .env and update with your values

# =============================================================================
# Application shell (APP_)
# =============================================================================
APP_ENV=production
# APP_ORGANIZATION_NAME=LDAP User Manager
# APP_SITE_NAME=LDAP User Manager
# APP_HTTP_HOST=app.example.org
# APP_HTTP_PATH=/
# Optional: full public URL for email links when it differs from in-container hostname
# APP_PUBLIC_BASE_URL=https://app.example.org/
# APP_LOGIN_LDAP_ATTRIBUTE=mail
# APP_LOGIN_FIELD_LABEL=Email
# Set APP_SERVE_HTTP_ONLY=true only when terminating TLS upstream or for local HTTP dev
APP_SERVE_HTTP_ONLY=true

# Writable directory for setup lock, rate-limit, and consumed-token state (multi-replica: use shared volume)
# APP_STATE_DIR=/var/lib/ldap_user_manager

# Setup wizard lock: APP_SETUP_LOCK_FILE overrides path; APP_SETUP_LOCKED=false skips lock (development)
# APP_SETUP_LOCK_FILE=
# APP_SETUP_LOCKED=

# Manage UI: LDAP user-bind fallback after failed bind (default true); APP_DEBUG_MANAGE_LDAP_BIND for bind-mode bar
# LDAP_FALLBACK_ADMIN_ON_FAILED_USER_BIND=true
# APP_DEBUG_MANAGE_LDAP_BIND=

# TLS cert filenames relative to container /opt/ssl (HTTPS VirtualHost branch in entrypoint; not used when APP_SERVE_HTTP_ONLY=true)
# APP_HTTP_PORT=443
# APP_TLS_CERT_FILE=server.crt
# APP_TLS_KEY_FILE=server.key
# APP_TLS_CA_CHAIN_FILE=

# =============================================================================
# OIDC Configuration
# Required only when OIDC_ENABLED=true
# =============================================================================
OIDC_ENABLED=true
OIDC_ISSUER=https://id.example.org
OIDC_CLIENT_ID=ldap-user-manager
OIDC_CLIENT_SECRET=<CHANGEME-oidc-client-secret>
OIDC_REDIRECT_URI=https://app.example.org/oidc/callback
OIDC_SCOPES=openid profile email groups

# =============================================================================
# LDAP Connection Settings (LDAP_)
# =============================================================================
LDAP_URI=ldaps://ldap-server:636
LDAP_BASE_DN=dc=example,dc=com
LDAP_ADMIN_BIND_DN=cn=admin,dc=example,dc=com
LDAP_ADMIN_BIND_PWD=<CHANGEME-strong-ldap-admin-password>
# STARTTLS is enforced by default. Set to false only for ldaps:// connections or local dev.
LDAP_REQUIRE_STARTTLS=true
# Certificate validation is enforced by default. Never set to true in production.
LDAP_IGNORE_CERT_ERRORS=false

# =============================================================================
# LDAP Structure
# =============================================================================
LDAP_USER_OU=people
LDAP_ORG_OU=organizations
LDAP_GROUP_OU=roles
LDAP_ACCOUNT_ATTRIBUTE=mail
LDAP_USE_UUID_IDENTIFICATION=true
# LDAP_FORCE_RFC2307BIS=TRUE

# =============================================================================
# Role Name Configuration (must be unique)
# =============================================================================
LDAP_ADMIN_ROLE=administrators
LDAP_MAINTAINER_ROLE=maintainers
LDAP_ORG_ADMIN_ROLE=org_admin
LDAP_USER_ROLE=user

# =============================================================================
# Status Group Names (cn= values under ou=roles; used for membership/disabled flags)
# =============================================================================
LDAP_GROUP_MEMBER_ORGS=memberOrganizations
LDAP_GROUP_DISABLED_ORGS=disabledOrganizations
LDAP_GROUP_DISABLED_ACCOUNTS=disabledAccounts

# =============================================================================
# Security Settings (TLS / audit / password strength)
# =============================================================================
# SESSION_TIMEOUT is in minutes (default: 60 = 1 hour)
SESSION_TIMEOUT=60
# SESSION_SAVE_PATH=/var/lib/ldap_user_manager/sessions

PASSWORD_STRENGTH_MIN_SCORE=2
PASSWORD_STRENGTH_MIN_LENGTH=8
PASSWORD_STRENGTH_REQUIRE_UPPERCASE=TRUE
PASSWORD_STRENGTH_REQUIRE_LOWERCASE=TRUE
PASSWORD_STRENGTH_REQUIRE_NUMBERS=TRUE
ACCEPT_WEAK_PASSWORDS=false

AUDIT_LOG_ENABLED=TRUE
AUDIT_LOG_FILE=/var/log/ldap_user_manager/audit.log

# =============================================================================
# Organization change history (OpenLDAP accesslog overlay)
# =============================================================================
# LDAP_ACCESSLOG_ENABLED=false

# =============================================================================
# User-bound /manage and setup — see docs/ldap/userbind-acls.md
# Override MDB DN: LDAP_OLC_MDB_DN=olcDatabase={1}mdb,cn=config

# =============================================================================
# User Management Defaults
# =============================================================================
DEFAULT_USER_GROUP=everybody
USERNAME_FORMAT={first_name}-{last_name}
PASSWORD_HASH=SSHA

# =============================================================================
# Account Requests (requires SMTP)
# =============================================================================
ACCOUNT_REQUESTS_ENABLED=true

# =============================================================================
# Password set/reset link tokens (requires SMTP)
# PASSWORD_RESET_TOKEN_SECRET=
# PASSWORD_RESET_TOKEN_TTL_SECONDS=3600

# =============================================================================
# Debug Settings
# =============================================================================
LDAP_DEBUG=false
SESSION_DEBUG=false
SETUP_DEBUG=false

# =============================================================================
# Optional: Email / SMTP (SMTP_EMAIL_)
# =============================================================================
# SMTP_HOSTNAME=smtp.example.com
# SMTP_USERNAME=noreply@example.com
# SMTP_PASSWORD=your-smtp-password
# SMTP_HOST_PORT=587
# SMTP_USE_TLS=TRUE
# EMAIL_FROM_ADDRESS=noreply@example.com
# EMAIL_FROM_NAME=LDAP User Manager
# EMAIL_TEMPLATES_DIR=
# EMAIL_DEFAULT_LOCALE=
# EMAIL_USER_LOCALE_LDAP_ATTR=preferredLanguage
# EMAIL_ORG_LOCALE_LDAP_ATTR=
# EMAIL_COUNTRY_LOCALE_MAP=
# PHPMAILER_CUSTOM_PATH=

# =============================================================================
# Member Organizations Export (EXPORT_)
# =============================================================================
# EXPORT_SHARED_SECRET=
# EXPORT_TYPO3_PAGE_ID=0

# =============================================================================
# Production overrides reminder
# =============================================================================
# APP_ENV=production
# APP_SERVE_HTTP_ONLY=false
# LDAP_IGNORE_CERT_ERRORS=false
# LDAP_REQUIRE_STARTTLS=true
# EXPORT_SHARED_SECRET=<output of: openssl rand -hex 32>
# PASSWORD_RESET_TOKEN_SECRET=<output of: openssl rand -hex 32>

# =============================================================================
# Upgrade: previous variable names (breaking change — set the APP_/LDAP_/EXPORT_
# equivalents above instead; these are listed for migration only — not read by code)
# =============================================================================
# ENVIRONMENT → APP_ENV
# ORGANISATION_NAME → APP_ORGANIZATION_NAME
# SITE_NAME → APP_SITE_NAME
# SERVER_HOSTNAME → APP_HTTP_HOST
# SERVER_PATH → APP_HTTP_PATH
# SITE_PUBLIC_URL → APP_PUBLIC_BASE_URL
# SITE_LOGIN_LDAP_ATTRIBUTE → APP_LOGIN_LDAP_ATTRIBUTE
# SITE_LOGIN_FIELD_LABEL → APP_LOGIN_FIELD_LABEL
# NO_HTTPS → APP_SERVE_HTTP_ONLY
# SERVER_PORT → APP_HTTP_PORT
# SERVER_CERT_FILENAME → APP_TLS_CERT_FILE
# SERVER_KEY_FILENAME → APP_TLS_KEY_FILE
# CA_CERT_FILENAME → APP_TLS_CA_CHAIN_FILE
# LUM_STATE_DIR → APP_STATE_DIR
# LDAP_SETUP_LOCK_FILE → APP_SETUP_LOCK_FILE
# LDAP_SETUP_LOCKED → APP_SETUP_LOCKED
# LUM_WRITE_BIND_FALLBACK → LDAP_FALLBACK_ADMIN_ON_FAILED_USER_BIND
# LUM_DEBUG_MANAGE_BIND → APP_DEBUG_MANAGE_LDAP_BIND
# FORCE_RFC2307BIS → LDAP_FORCE_RFC2307BIS
# PHPMailer_PATH → PHPMAILER_CUSTOM_PATH
# TYPO3_EXPORT_PID → EXPORT_TYPO3_PAGE_ID
